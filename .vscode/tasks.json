{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Debug Server",
            "type": "shell",
            "command": "sh",
            "args": ["-c", "west debugserver --runner openocd"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Stop Debug Server",
            "type": "shell",
            "command": "pkill",
            "args": ["-f", "openocd"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}