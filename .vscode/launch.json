    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "external",
            "gdbPath": "/home/vscode/zephyr-sdk-0.17.2/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "gdbTarget": "localhost:3333",
            "device": "STM32F411RE",
            // "preLaunchTask": "gdbserver: start",
            // "postDebugTask": "gdbserver: stop",
            "executable": "${workspaceFolder}/build/zephyr/zephyr.elf",
            "svdFile": "${workspaceFolder}/build/zephyr/zephyr.elf.svd",
            "showDevDebugOutput": "none"
        }
    ]
}